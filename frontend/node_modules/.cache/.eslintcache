\nimport { useAuth0 } from '@auth0/auth0-react';\r\nimport JSONPretty from 'react-json-pretty';\r\n\r\nfunction Profile() {\r\n    const {user, isAuthenticated} = useAuth0();\r\n\r\n    return(\r\n        isAuthenticated && (\r\n            <div>\r\n                <img src={user.picture} alt={user.name} />\r\n                <span>  {user.name} </span><span> {user.email}</span>\r\n            </div>\r\n        )\r\n    )\r\n}\r\n\r\nexport default Profile;","C:\\Ahnaf\\CS\\Practice\\Journal\\frontend\\src\\index.js",[],"C:\\Ahnaf\\CS\\Practice\\Journal\\frontend\\src\\App.js",[],"C:\\Ahnaf\\CS\\Practice\\Journal\\frontend\\src\\components\\LogoutButton.js",[],"C:\\Ahnaf\\CS\\Practice\\Journal\\frontend\\src\\components\\LoginButton.js",[],"C:\\Ahnaf\\CS\\Practice\\Journal\\frontend\\src\\components\\Profile.js",[],"C:\\Ahnaf\\CS\\Practice\\Journal\\frontend\\src\\components\\trades\\index.js",["85"],"import React, { useState, useEffect } from 'react';\r\nimport TradeForm from './TradeForm';\r\nimport TradeList from './TradeList';\r\nimport Chart from './Chart';\r\nimport axios from 'axios';\r\nimport { useAuth0 } from '@auth0/auth0-react';\r\n\r\n\r\nfunction Trades() {\r\n    const [tradeList, setTradeList] = useState([])\r\n    const {user} = useAuth0()\r\n\r\n    useEffect(() => {\r\n        axios.get('http://localhost:8888/trades', {})\r\n            .then(res => {\r\n                const userTrades = res.data.filter(item => {\r\n                    return item.user === user.email\r\n                })\r\n                setTradeList(userTrades)\r\n            })\r\n            .catch(err => {\r\n                console.log(err)\r\n            })\r\n    }, [])\r\n\r\n    const deleteHandler = id => {\r\n        axios.delete(`http://localhost:8888/trades/${id}`)\r\n            .then(res => {\r\n                const newTrades = tradeList.filter(item => {\r\n                    return item.id !== id\r\n                })\r\n                setTradeList(newTrades)\r\n            })\r\n            .catch(err => {\r\n                console.log(err)\r\n            })\r\n    }\r\n\r\n    return(\r\n        <div>\r\n            <TradeForm tradeList={tradeList} setTradeList={setTradeList} />\r\n            <Chart tradeList={tradeList} />\r\n            <TradeList tradeList={tradeList} deleteHandler={deleteHandler} />\r\n        </div>    \r\n    )\r\n}\r\n\r\nexport default Trades;","C:\\Ahnaf\\CS\\Practice\\Journal\\frontend\\src\\components\\trades\\TradeList.js",[],"C:\\Ahnaf\\CS\\Practice\\Journal\\frontend\\src\\components\\trades\\TradeForm.js",[],"C:\\Ahnaf\\CS\\Practice\\Journal\\frontend\\src\\components\\trades\\Chart.js",[],"C:\\Ahnaf\\CS\\Practice\\Journal\\frontend\\src\\components\\trades\\Trade.js",[],{"ruleId":"86","replacedBy":"87"},{"ruleId":"88","replacedBy":"89"},{"ruleId":"90","severity":1,"message":"91","line":3,"column":8,"nodeType":"92","messageId":"93","endLine":3,"endColumn":18},{"ruleId":"94","severity":1,"message":"95","line":24,"column":8,"nodeType":"96","endLine":24,"endColumn":10,"suggestions":"97"},"no-native-reassign",["98"],"no-negated-in-lhs",["99"],"no-unused-vars","'JSONPretty' is defined but never used.","Identifier","unusedVar","react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'user.email'. Either include it or remove the dependency array.","ArrayExpression",["100"],"no-global-assign","no-unsafe-negation",{"desc":"101","fix":"102"},"Update the dependencies array to be: [user.email]",{"range":"103","text":"104"},[730,732],"[user.email]"]